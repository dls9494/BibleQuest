rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews'])
         && request.resource.data.profileViews == resource.data.profileViews + 1)
      );
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /reading_plan {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /reading_plan/{planId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Referral rules
    match /referrals/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Quiz collection rules
    match /quizzes/{quizId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }
    
    // Real questions caching rules
    match /real_questions/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Daily challenges rules
    match /daily_challenges/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Weekly challenges rules
    match /weekly_challenges/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Monthly challenges rules
    match /monthly_challenges/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Leaderboard rules - only allow user to update their own document
    match /weekly_leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && (resource == null || request.resource.data.score >= resource.data.score);
    }

    match /monthly_leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && (resource == null || request.resource.data.score >= resource.data.score);
    }

    match /leaderboard_all_time/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && (resource == null || request.resource.data.score >= resource.data.score);
    }
    
    // Real-time game sessions rules
    match /game_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.hostId;
      
      match /players/{playerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == playerId;
        allow update: if request.auth != null && request.auth.uid == playerId;
        
        match /answers/{answerId} {
          allow read: if request.auth != null;
          allow write: if request.auth != null && request.auth.uid == playerId;
        }
      }
    }

    // Prayer requests collection rules
    match /prayer_requests/{requestId} {
      // Anyone authenticated can read
      allow read: if request.auth != null;
      // Authenticated users can create
      allow create: if request.auth != null 
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.request is string
        && request.resource.data.request.size() <= 500;
      // Only the creator can delete their own request
      allow delete: if request.auth != null 
        && resource.data.userId == request.auth.uid;
      // Anyone authenticated can update prayer count OR reactions maps OR the owner can update their document
      allow update: if request.auth != null && (
        // Owner updates their own document
        (resource.data.userId == request.auth.uid)
        ||
        // Anyone authenticated can increment prayer count ONLY
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayerCount'])
         && request.resource.data.prayerCount == resource.data.prayerCount + 1)
        ||
        // Anyone authenticated can update reactions/userReactions ONLY
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'userReactions'])
         && request.resource.data.userReactions.diff(resource.data.userReactions).affectedKeys().hasOnly([request.auth.uid]))
      );
    }

    // Church Groups rules
    match /church_groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.pastorId == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid == resource.data.pastorId;
      allow delete: if request.auth != null && resource.data.pastorId == request.auth.uid;
    }

    // Group challenges rules
    match /group_challenges/{challengeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        get(/databases/$(database)/documents/church_groups/$(request.resource.data.groupId)).data.pastorId == request.auth.uid;
      allow update: if request.auth != null && (
        // Pastor can update anything
        get(/databases/$(database)/documents/church_groups/$(resource.data.groupId)).data.pastorId == request.auth.uid ||
        // Members can only update their own participant scores
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantScores'])
         && request.resource.data.participantScores.diff(resource.data.participantScores).affectedKeys().hasOnly([request.auth.uid]))
      );
      allow delete: if request.auth != null && 
        get(/databases/$(database)/documents/church_groups/$(resource.data.groupId)).data.pastorId == request.auth.uid;
    }

    // Follows rules
    match /follows/{followId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.followerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.followerId;
    }

    // Activities rules
    match /activities/{activityId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // Notes rules - only allow authenticated user to read/write their own notes
    match /notes/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /chapter_notes/{noteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Labelled and Favorited verses rules
    match /users/{userId}/labelled_verses/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/favorited_verses/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
